# Add ANY ONE of these — app uses whichever it finds, in this order:
# 1. Anthropic (best quality, $5 free credit at console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# 2. Groq (FREE, no card — console.groq.com)
GROQ_API_KEY=your_grok_key_here

# 3. Gemini (free tier — aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# 4. OpenRouter (free models — openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional — Whisper voice upgrade (openai.com, needs card)
OPENAI_API_KEY=your_openai_key_here

PORT=3000